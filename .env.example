# Copy to .env and edit for your host.
COMPOSE_PROJECT_NAME=openpi_droid

# The compose file already mounts /dev, /dev/bus/usb, and /run/udev.
# These variables are consumed by the DROID camera readers.
DROID_ARDUCAM_LEFT_DEVICE=/dev/video0
DROID_ARDUCAM_RIGHT_DEVICE=/dev/video2
DROID_D435_SERIAL=

# Set to 1 only if you want bootstrap_fairo_franka.sh to initialize or clone FAIRO.
DROID_BOOTSTRAP_FAIRO_SUBMODULE=0

# Real robot motion is refused unless both are set to 1.
DROID_ENABLE_ROBOT_MOTION=0
CONFIRM_REAL_ROBOT=0
