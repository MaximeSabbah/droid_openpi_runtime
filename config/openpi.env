OPENPI_HOST=127.0.0.1
OPENPI_PORT=8000
# pi05_droid is the current default but ignores observation/exterior_image_2_left.
# Use pi0_fast_droid + gs://openpi-assets/checkpoints/pi0_fast_droid when you want
# the second external Arducam to feed the model's base_1_rgb input.
OPENPI_POLICY_CONFIG=pi05_droid
OPENPI_POLICY_DIR=gs://openpi-assets/checkpoints/pi05_droid
OPENPI_PROMPT=
