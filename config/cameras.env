DROID_CAMERA_BACKEND=openpi
DROID_HAND_CAMERA_ID=d435_color
DROID_VARIED_CAMERA_1_ID=arducam_left
# Leave blank when only one external Arducam is connected.
DROID_VARIED_CAMERA_2_ID=

# Prefer /dev/v4l/by-id symlinks over /dev/videoN; video numbers can move after reconnects.
DROID_ARDUCAM_LEFT_DEVICE=/dev/v4l/by-id/usb-Arducam_Arducam_B0495__USB3_2.3MP__Arducam_20231205_0001-video-index0
DROID_ARDUCAM_RIGHT_DEVICE=
DROID_ARDUCAM_LEFT_WARMUP_FRAMES=12

# Leave empty to use the first RealSense D435. Set to the camera serial for multi-D435 hosts.
DROID_D435_SERIAL=
DROID_D435_COLOR_WIDTH=640
DROID_D435_COLOR_HEIGHT=480
DROID_D435_COLOR_FPS=30
