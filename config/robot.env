DROID_ROBOT_BACKEND=local
DROID_ROBOT_TYPE=panda
DROID_NUC_IP=
DROID_ROBOT_IP=172.17.1.2
DROID_LAPTOP_IP=127.0.0.1
DROID_ROBOT_SERIAL_NUMBER=SET_ROBOT_SERIAL_NUMBER

# Container runs as root/privileged, so do not route launch scripts through sudo.
DROID_LAUNCH_WITH_SUDO=0
DROID_ROBOT_RUNTIME_ENV=polymetis-local
DROID_POLYMETIS_CONDA_ENV=polymetis-local
DROID_ENV_ACTIVATE=eval "$(micromamba shell hook --shell bash)" && micromamba activate polymetis-local
DROID_FAIRO_DIR=/workspace/droid/droid/fairo
DROID_POLYMETIS_DIR=/workspace/droid/droid/fairo/polymetis
DROID_POLYMETIS_CONFIG_DIR=/workspace/runtime_config/polymetis

# The bootstrap installs DROID's Franka configs into the runtime overlay above.
DROID_ROBOT_CLIENT_CONFIG=droid_franka_hardware
DROID_ROBOT_MODEL_CONFIG=droid_franka_panda
DROID_GRIPPER_LAUNCH_CMD=launch_gripper.py gripper=franka_hand gripper.executable_cfg.robot_ip=172.17.1.2

# Real robot motion remains disabled until explicitly changed in .env.
DROID_ENABLE_ROBOT_MOTION=0
CONFIRM_REAL_ROBOT=0
